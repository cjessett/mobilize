<%= render "shared/flash" %>

<div class="flex items-center justify-between mb-4">
  <h1 class="font-bold text-3xl">Email blasts</h1>
  <%= link_to "New email blast", new_email_blast_path, class: "rounded-md px-3.5 py-2 bg-blue-600 hover:bg-blue-500 text-white text-sm font-medium" %>
</div>

<div class="bg-white rounded-lg border border-gray-200 divide-y divide-gray-100">
  <% if @email_blasts.empty? %>
    <p class="p-6 text-gray-500">No email blasts yet.</p>
  <% end %>
  <% @email_blasts.each do |blast| %>
    <div class="p-4 flex items-center justify-between">
      <div>
        <%= link_to blast.name, blast, class: "font-medium text-blue-700 hover:underline" %>
        <div class="text-sm text-gray-500"><%= blast.subject %></div>
      </div>
      <span class="text-xs rounded-full px-2 py-0.5 <%= { 'draft' => 'bg-gray-100 text-gray-600', 'scheduled' => 'bg-yellow-50 text-yellow-700', 'sending' => 'bg-blue-50 text-blue-700', 'sent' => 'bg-green-50 text-green-700', 'failed' => 'bg-red-50 text-red-600', 'canceled' => 'bg-gray-100 text-gray-400' }[blast.status] %>"><%= blast.status %></span>
    </div>
  <% end %>
</div>

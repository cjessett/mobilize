<%= form_with model: email_blast, class: "contents" do |form| %>
  <% if email_blast.errors.any? %>
    <p class="py-2 px-3 bg-red-50 mb-5 text-red-500 font-medium rounded-lg inline-block"><%= email_blast.errors.full_messages.to_sentence %></p>
  <% end %>

  <div class="my-5 grid md:grid-cols-2 gap-4">
    <div>
      <%= form.label :name, "Internal name", class: "block text-sm font-medium text-gray-700" %>
      <%= form.text_field :name, required: true, class: "block shadow-sm rounded-md border border-gray-400 px-3 py-2 mt-2 w-full bg-white" %>
    </div>
    <div>
      <%= form.label :subject, class: "block text-sm font-medium text-gray-700" %>
      <%= form.text_field :subject, required: true, class: "block shadow-sm rounded-md border border-gray-400 px-3 py-2 mt-2 w-full bg-white" %>
    </div>
  </div>

  <div class="my-5">
    <%= form.label :body, class: "block text-sm font-medium text-gray-700 mb-2" %>
    <div class="bg-white rounded-md border border-gray-300 [&_trix-editor]:min-h-48 [&_trix-editor]:px-3 [&_trix-editor]:py-2">
      <%= form.rich_text_area :body %>
    </div>
    <p class="text-xs text-gray-400 mt-1">Merge tags: {{first_name}}, {{last_name}}, {{name}}, {{chapter_name}}.</p>
  </div>

  <div class="my-5 flex gap-4">
    <div>
      <%= form.label :segment_id, "Audience", class: "block text-sm font-medium text-gray-700" %>
      <%= form.select :segment_id, [ [ "Everyone (all people)", "" ] ] + Segment.visible_to(current_membership).order(:name).map { |s| [ s.name, s.id ] }, {}, { class: "block shadow-sm rounded-md border border-gray-300 px-3 py-2 mt-2 bg-white" } %>
    </div>
    <div>
      <label class="block text-sm font-medium text-gray-700">Scope</label>
      <%= select_tag "email_blast[access_scope_gid]",
            options_for_select(
              [ [ "Organization-wide", "organization" ] ] + current_organization.chapters.order(:name).map { |c| [ c.name, "chapter-#{c.id}" ] },
              email_blast.access_scope.is_a?(Chapter) ? "chapter-#{email_blast.access_scope_id}" : "organization"
            ),
            class: "block shadow-sm rounded-md border border-gray-300 px-3 py-2 mt-2 bg-white" %>
    </div>
  </div>

  <%= form.submit email_blast.persisted? ? "Save" : "Create email blast", class: "rounded-md px-3.5 py-2.5 bg-blue-600 hover:bg-blue-500 text-white font-medium cursor-pointer" %>
<% end %>

<%= form_with model: email_blast, class: "contents" do |form| %>
  <% if email_blast.errors.any? %>
    <p class="py-2 px-3 bg-red-500/10 mt-4 text-red-600 dark:text-red-400 font-medium rounded-lg inline-block"><%= email_blast.errors.full_messages.to_sentence %></p>
  <% end %>

  <%= form_card do %>
    <%= form_row "Blast name", hint: "Internal name, not shown to recipients." do %>
      <%= form.text_field :name, required: true, class: ui_input %>
    <% end %>

    <%= form_row "Subject" do %>
      <%= form.text_field :subject, required: true, class: ui_input %>
    <% end %>

    <%= form_row "Body", hint: "Merge tags: {{first_name}}, {{last_name}}, {{name}}, {{chapter_name}}." do %>
      <div class="rounded-md border border-gray-300 dark:border-slate-600 bg-gray-50 dark:bg-slate-900/70 [&_trix-editor]:min-h-48 [&_trix-editor]:px-3 [&_trix-editor]:py-2">
        <%= form.rich_text_area :body %>
      </div>
    <% end %>

    <%= form_row "Audience" do %>
      <%= form.select :segment_id, [ [ "Everyone (all people)", "" ] ] + Segment.visible_to(current_membership).order(:name).map { |s| [ s.name, s.id ] }, {}, { class: ui_input } %>
    <% end %>

    <%= form_row "Scope" do %>
      <%= select_tag "email_blast[access_scope_gid]",
            options_for_select(
              [ [ "Organization-wide", "organization" ] ] + current_organization.chapters.order(:name).map { |c| [ c.name, "chapter-#{c.id}" ] },
              email_blast.access_scope.is_a?(Chapter) ? "chapter-#{email_blast.access_scope_id}" : "organization"
            ),
            class: ui_input %>
    <% end %>

    <%= form_actions do %>
      <%= form.submit email_blast.persisted? ? "Save Email Blast" : "Create Email Blast", class: "rounded-md px-4 py-2.5 bg-indigo-500 hover:bg-indigo-400 text-white font-medium cursor-pointer" %>
    <% end %>
  <% end %>
<% end %>

<div style="max-width: 600px; margin: 0 auto; font-family: sans-serif; color: #1f2937;">
  <h2 style="margin-bottom: 4px;"><%= @event.title %></h2>
  <p style="margin-top: 0; color: #6b7280;"><%= @time %><%= " · #{@session.location}" if @session.location.present? %></p>

  <% if @session.virtual_url.present? %>
    <p><a href="<%= @session.virtual_url %>" style="color: #4f46e5;">Join online</a></p>
  <% end %>

  <% if @event.description.present? %>
    <%= simple_format @event.description %>
  <% end %>

  <% if @event.confirmation_days_before.present? && @rsvp.confirmed_at.nil? %>
    <p style="margin: 24px 0;">
      <a href="<%= @confirm_url %>" style="background: #4f46e5; color: #fff; padding: 10px 18px; border-radius: 6px; text-decoration: none;">Yes, I'll be there</a>
    </p>
  <% end %>

  <p style="font-size: 12px; color: #9ca3af;">A calendar invite is attached. Sent by <%= @event.organization.name %>.</p>
</div>

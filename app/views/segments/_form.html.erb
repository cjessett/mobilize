<%= form_with model: segment, class: "contents", data: { controller: "conditions" } do |form| %>
  <% if segment.errors.any? %>
    <p class="py-2 px-3 bg-red-500/10 mb-5 text-red-600 dark:text-red-400 font-medium rounded-lg inline-block"><%= segment.errors.full_messages.to_sentence %></p>
  <% end %>

  <div class="my-5">
    <%= form.label :name, class: "block text-sm font-medium text-gray-700 dark:text-slate-300" %>
    <%= form.text_field :name, required: true, class: "block shadow-sm rounded-md border border-gray-300 dark:border-slate-600 px-3 py-2 mt-2 w-full md:w-1/2 bg-white dark:bg-slate-800/60" %>
  </div>

  <div class="my-5 flex gap-4 items-center">
    <label class="text-sm font-medium text-gray-700 dark:text-slate-300">Match</label>
    <%= select_tag "segment[match]", options_for_select([ [ "All conditions", "all" ], [ "Any condition", "any" ] ], segment.match_any? ? "any" : "all"), class: "shadow-sm rounded-md border border-gray-300 dark:border-slate-600 px-3 py-2 bg-white dark:bg-slate-800/60" %>
    <label class="text-sm font-medium text-gray-700 dark:text-slate-300 ml-4">Scope</label>
    <%= select_tag "segment[access_scope_gid]",
          options_for_select(
            [ [ "Organization-wide", "organization" ] ] + current_organization.chapters.order(:name).map { |c| [ c.name, "chapter-#{c.id}" ] },
            segment.access_scope.is_a?(Chapter) ? "chapter-#{segment.access_scope_id}" : "organization"
          ),
          class: "shadow-sm rounded-md border border-gray-300 dark:border-slate-600 px-3 py-2 bg-white dark:bg-slate-800/60" %>
  </div>

  <h3 class="font-semibold text-sm text-gray-700 dark:text-slate-300 mb-2">Conditions</h3>
  <div data-conditions-target="rows" class="space-y-2">
    <% segment.conditions.each do |condition| %>
      <%= render "condition_row", condition: condition %>
    <% end %>
  </div>

  <template data-conditions-target="template">
    <%= render "condition_row", condition: {} %>
  </template>

  <button type="button" data-action="conditions#add" class="mt-3 text-sm text-indigo-600 dark:text-indigo-400 hover:underline cursor-pointer">+ Add condition</button>

  <div class="mt-6">
    <%= form.submit segment.persisted? ? "Save segment" : "Create segment", class: "rounded-md px-3.5 py-2.5 bg-indigo-600 hover:bg-indigo-500 text-white font-medium cursor-pointer" %>
  </div>
<% end %>

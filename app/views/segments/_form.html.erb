<%= form_with model: segment, class: "contents", data: { controller: "conditions" } do |form| %>
  <% if segment.errors.any? %>
    <p class="py-2 px-3 bg-red-500/10 mt-4 text-red-600 dark:text-red-400 font-medium rounded-lg inline-block"><%= segment.errors.full_messages.to_sentence %></p>
  <% end %>

  <%= form_card do %>
    <%= form_row "List name" do %>
      <%= form.text_field :name, required: true, class: ui_input %>
    <% end %>

    <%= form_row "Match", hint: "Whether people must match all conditions or any one of them." do %>
      <%= select_tag "segment[match]", options_for_select([ [ "All conditions", "all" ], [ "Any condition", "any" ] ], segment.match_any? ? "any" : "all"), class: ui_input %>
    <% end %>

    <%= form_row "Scope" do %>
      <%= select_tag "segment[access_scope_gid]",
            options_for_select(
              [ [ "Organization-wide", "organization" ] ] + current_organization.chapters.order(:name).map { |c| [ c.name, "chapter-#{c.id}" ] },
              segment.access_scope.is_a?(Chapter) ? "chapter-#{segment.access_scope_id}" : "organization"
            ),
            class: ui_input %>
    <% end %>

    <%= form_row "Conditions" do %>
      <div data-conditions-target="rows" class="space-y-2">
        <% segment.conditions.each do |condition| %>
          <%= render "condition_row", condition: condition %>
        <% end %>
      </div>

      <template data-conditions-target="template">
        <%= render "condition_row", condition: {} %>
      </template>

      <button type="button" data-action="conditions#add" class="mt-3 text-sm text-indigo-600 dark:text-indigo-400 hover:underline cursor-pointer">+ Add condition</button>
    <% end %>

    <%= form_actions do %>
      <%= form.submit segment.persisted? ? "Save List" : "Create List", class: "rounded-md px-4 py-2.5 bg-indigo-500 hover:bg-indigo-400 text-white font-medium cursor-pointer" %>
    <% end %>
  <% end %>
<% end %>

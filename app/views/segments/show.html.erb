<%= render "shared/flash" %>

<div class="flex items-center justify-between mb-4">
  <div>
    <h1 class="font-bold text-3xl"><%= @segment.name %></h1>
    <p class="text-gray-500 text-sm mt-1"><%= @people.size %> people<%= @people.size == 200 ? "+ (showing first 200)" : "" %></p>
  </div>
  <div class="flex gap-2">
    <%= link_to "Edit", edit_segment_path(@segment), class: "rounded-md px-3.5 py-2 border border-gray-300 bg-white hover:bg-gray-100 text-sm font-medium" %>
    <%= button_to "Delete", @segment, method: :delete, data: { turbo_confirm: "Delete this segment?" }, class: "rounded-md px-3.5 py-2 border border-red-200 text-red-600 bg-white hover:bg-red-50 text-sm font-medium cursor-pointer" %>
  </div>
</div>

<div class="bg-white rounded-lg border border-gray-200 divide-y divide-gray-100">
  <% @people.each do |person| %>
    <div class="p-4 flex items-center justify-between">
      <div>
        <%= link_to person.name, person, class: "font-medium text-blue-700 hover:underline" %>
        <div class="text-sm text-gray-500"><%= [ person.phone, person.email ].compact_blank.join(" · ") %></div>
      </div>
      <div class="flex gap-2">
        <% person.tags.each do |tag| %>
          <span class="text-xs bg-gray-100 text-gray-600 rounded-full px-2 py-0.5"><%= tag.name %></span>
        <% end %>
      </div>
    </div>
  <% end %>
</div>

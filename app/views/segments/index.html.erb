<%= render "shared/flash" %>

<div class="flex flex-wrap items-center justify-between gap-3 mb-6">
  <h1 class="font-bold text-3xl text-gray-900 dark:text-white">Lists</h1>
  <%= link_to "Create New List", new_segment_path, class: "rounded-md px-4 py-2 bg-indigo-600 hover:bg-indigo-500 text-white text-sm font-medium" %>
</div>

<div class="bg-white dark:bg-slate-800/40 rounded-xl border border-gray-200 dark:border-slate-700/70">
  <div class="overflow-x-auto">
  <table class="w-full text-left min-w-[40rem]">
    <thead>
      <tr class="text-xs uppercase tracking-wider text-gray-400 dark:text-slate-500">
        <th class="px-6 py-4 font-semibold">Name</th>
        <th class="px-4 py-4 font-semibold">Conditions</th>
        <th class="px-4 py-4 font-semibold">Scope</th>
        <th class="px-4 py-4 font-semibold">People</th>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-200 dark:divide-slate-700/60">
      <% if @segments.empty? %>
        <tr><td colspan="4" class="px-6 py-8 text-gray-500 dark:text-slate-400">No lists yet. Lists are saved filters over your people.</td></tr>
      <% end %>
      <% @segments.each do |segment| %>
        <tr class="hover:bg-gray-50 dark:hover:bg-slate-800">
          <td class="px-6 py-4"><%= link_to segment.name, segment, class: "font-medium text-gray-900 dark:text-white hover:text-indigo-600 dark:hover:text-indigo-300" %></td>
          <td class="px-4 py-4 text-sm text-gray-700 dark:text-slate-300"><%= pluralize(segment.conditions.size, "condition") %></td>
          <td class="px-4 py-4 text-sm text-gray-700 dark:text-slate-300"><%= segment.org_scoped? ? "Organization" : segment.chapter.name %></td>
          <td class="px-4 py-4 text-sm text-gray-700 dark:text-slate-300"><%= segment.people.count %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
  </div>
</div>

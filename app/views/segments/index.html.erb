<%= render "shared/flash" %>

<div class="flex items-center justify-between mb-4">
  <h1 class="font-bold text-3xl">Segments</h1>
  <%= link_to "New segment", new_segment_path, class: "rounded-md px-3.5 py-2 bg-indigo-600 hover:bg-indigo-500 text-white text-sm font-medium" %>
</div>

<div class="bg-white dark:bg-slate-800/60 rounded-lg border border-gray-200 dark:border-slate-700/70 divide-y divide-gray-200 dark:divide-slate-700/60">
  <% if @segments.empty? %>
    <p class="p-6 text-gray-500 dark:text-slate-400">No segments yet. Segments are saved filters over your people.</p>
  <% end %>
  <% @segments.each do |segment| %>
    <div class="p-4 flex items-center justify-between">
      <div>
        <%= link_to segment.name, segment, class: "font-medium text-indigo-600 dark:text-indigo-400 hover:underline" %>
        <div class="text-sm text-gray-500 dark:text-slate-400">
          <%= pluralize(segment.conditions.size, "condition") %>
          · <%= segment.org_scoped? ? "Organization-wide" : segment.chapter.name %>
        </div>
      </div>
      <span class="text-sm text-gray-400 dark:text-slate-500"><%= segment.people.count %> people</span>
    </div>
  <% end %>
</div>

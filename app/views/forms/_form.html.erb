<%= form_with model: form, class: "contents" do |f| %>
  <% if form.errors.any? %>
    <p class="py-2 px-3 bg-red-500/10 mt-4 text-red-600 dark:text-red-400 font-medium rounded-lg inline-block"><%= form.errors.full_messages.to_sentence %></p>
  <% end %>

  <%= form_card do %>
    <%= form_row "Title" do %>
      <%= f.text_field :title, required: true, class: ui_input %>
    <% end %>

    <%= form_row "Type" do %>
      <div class="space-y-4">
        <% { "signup" => [ "Signup", "Collect new supporters into your CRM." ],
             "petition" => [ "Petition", "Public signature count with an optional goal." ] }.each do |value, (label, description)| %>
          <label class="flex items-start gap-3 cursor-pointer">
            <%= f.radio_button :kind, value, class: "mt-1 h-5 w-5 accent-indigo-500" %>
            <span>
              <span class="block font-medium text-gray-900 dark:text-white"><%= label %></span>
              <span class="block text-sm text-gray-400 dark:text-slate-500"><%= description %></span>
            </span>
          </label>
        <% end %>
      </div>
    <% end %>

    <%= form_row "Goal", hint: "Petitions show progress toward this signature goal." do %>
      <%= f.number_field :goal, min: 1, class: "#{ui_input} md:w-40" %>
    <% end %>

    <%= form_row "Description" do %>
      <%= f.text_area :description, rows: 3, class: ui_input %>
    <% end %>

    <%= form_row "Confirmation message", hint: "Shown after someone submits." do %>
      <%= f.text_field :confirmation_message, placeholder: "Thanks — you're in!", class: ui_input %>
    <% end %>

    <%= form_row "Apply tag", hint: "Added to everyone who submits." do %>
      <%= text_field_tag "form[apply_tag_name]", form.apply_tag&.name, placeholder: "e.g. petition-signer", class: ui_input %>
    <% end %>

    <%= form_row "Scope" do %>
      <%= select_tag "form[access_scope_gid]",
            options_for_select(
              [ [ "Organization-wide", "organization" ] ] + current_organization.chapters.order(:name).map { |c| [ c.name, "chapter-#{c.id}" ] },
              form.access_scope.is_a?(Chapter) ? "chapter-#{form.access_scope_id}" : "organization"
            ),
            class: ui_input %>
    <% end %>

    <%= form_row "Fields", hint: "Add more fields under People → Properties." do %>
      <% existing = form.form_fields.index_by(&:key) %>
      <div class="rounded-md border border-gray-200 dark:border-slate-700 divide-y divide-gray-100 dark:divide-slate-700/60">
        <% Form::BUILTIN_FIELDS.merge(current_organization.custom_fields.pluck(:key, :label).to_h).each do |key, default_label| %>
          <% field = existing[key] %>
          <div class="p-3 flex flex-wrap items-center gap-3 md:gap-4">
            <label class="flex items-center gap-2 w-40 text-sm cursor-pointer">
              <%= check_box_tag "form[fields][#{key}][include]", "1", field.present? || (form.new_record? && Form::BUILTIN_FIELDS.key?(key)), class: "accent-indigo-500" %>
              <span class="font-medium text-gray-900 dark:text-white"><%= default_label %></span>
            </label>
            <label class="flex items-center gap-2 text-sm text-gray-400 dark:text-slate-500 cursor-pointer">
              <%= check_box_tag "form[fields][#{key}][required]", "1", field&.required? || (form.new_record? && key == "first_name"), class: "accent-indigo-500" %> required
            </label>
            <%= text_field_tag "form[fields][#{key}][label]", field&.label, placeholder: "Label override", class: "rounded-md border border-gray-300 dark:border-slate-600 bg-gray-50 dark:bg-slate-900/70 px-2 py-1.5 text-sm flex-1" %>
          </div>
        <% end %>
      </div>
    <% end %>

    <%= form_actions do %>
      <%= f.submit form.persisted? ? "Save Form" : "Create Form", class: "rounded-md px-4 py-2.5 bg-indigo-500 hover:bg-indigo-400 text-white font-medium cursor-pointer" %>
    <% end %>
  <% end %>
<% end %>

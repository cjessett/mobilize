<%= render "shared/flash" %>

<div class="flex items-center justify-between mb-4">
  <h1 class="font-bold text-3xl">Forms & petitions</h1>
  <div class="flex gap-2">
    <%= link_to "New petition", new_form_path(kind: "petition"), class: "rounded-md px-3.5 py-2 border border-gray-300 dark:border-slate-600 bg-white dark:bg-slate-800/60 hover:bg-gray-100 dark:hover:bg-slate-700 text-sm font-medium" %>
    <%= link_to "New signup form", new_form_path, class: "rounded-md px-3.5 py-2 bg-indigo-600 hover:bg-indigo-500 text-white text-sm font-medium" %>
  </div>
</div>

<div class="bg-white dark:bg-slate-800/60 rounded-lg border border-gray-200 dark:border-slate-700/70 divide-y divide-gray-200 dark:divide-slate-700/60">
  <% if @forms.empty? %>
    <p class="p-6 text-gray-500 dark:text-slate-400">No forms yet. Signup forms and petitions collect people straight into your CRM.</p>
  <% end %>
  <% @forms.each do |form| %>
    <div class="p-4 flex items-center justify-between">
      <div>
        <%= link_to form.title, form, class: "font-medium text-indigo-600 dark:text-indigo-400 hover:underline" %>
        <span class="text-xs bg-gray-200 dark:bg-slate-700 text-gray-700 dark:text-slate-300 rounded-full px-2 py-0.5 ml-2"><%= form.kind %></span>
      </div>
      <span class="text-sm text-gray-400 dark:text-slate-500">
        <%= form.signature_count %> <%= form.petition? ? "signatures" : "submissions" %><%= " / #{form.goal} goal" if form.goal %>
      </span>
    </div>
  <% end %>
</div>

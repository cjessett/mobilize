<%= render "shared/flash" %>

<div class="flex items-center justify-between mb-6">
  <h1 class="font-bold text-3xl text-gray-900 dark:text-white">Pages</h1>
  <div class="flex gap-2">
    <%= link_to "New Petition", new_form_path(kind: "petition"), class: "rounded-md px-4 py-2 border border-indigo-500/50 text-indigo-600 dark:text-indigo-300 hover:bg-indigo-500/10 text-sm font-medium" %>
    <%= link_to "New Signup Form", new_form_path, class: "rounded-md px-4 py-2 bg-indigo-600 hover:bg-indigo-500 text-white text-sm font-medium" %>
  </div>
</div>

<div class="bg-white dark:bg-slate-800/40 rounded-xl border border-gray-200 dark:border-slate-700/70">
  <table class="w-full text-left">
    <thead>
      <tr class="text-xs uppercase tracking-wider text-gray-400 dark:text-slate-500">
        <th class="px-6 py-4 font-semibold">Title</th>
        <th class="px-4 py-4 font-semibold">Type</th>
        <th class="px-4 py-4 font-semibold">Submissions</th>
        <th class="px-4 py-4 font-semibold">Goal</th>
        <th class="px-4 py-4 font-semibold">Scope</th>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-200 dark:divide-slate-700/60">
      <% if @forms.empty? %>
        <tr><td colspan="5" class="px-6 py-8 text-gray-500 dark:text-slate-400">No forms yet. Signup forms and petitions collect people straight into your CRM.</td></tr>
      <% end %>
      <% @forms.each do |form| %>
        <tr class="hover:bg-gray-50 dark:hover:bg-slate-800">
          <td class="px-6 py-4"><%= link_to form.title, form, class: "font-medium text-gray-900 dark:text-white hover:text-indigo-600 dark:hover:text-indigo-300" %></td>
          <td class="px-4 py-4"><%= status_pill form.kind.capitalize, form.petition? ? :blue : :gray %></td>
          <td class="px-4 py-4 text-sm text-gray-700 dark:text-slate-300"><%= form.signature_count %></td>
          <td class="px-4 py-4 text-sm text-gray-700 dark:text-slate-300"><%= form.goal || "—" %></td>
          <td class="px-4 py-4 text-sm text-gray-700 dark:text-slate-300"><%= form.org_scoped? ? "Organization" : form.chapter.name %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>

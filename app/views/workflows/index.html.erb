<%= render "shared/flash" %>

<div class="flex items-center justify-between mb-4">
  <h1 class="font-bold text-3xl">Workflows</h1>
  <%= link_to "New workflow", new_workflow_path, class: "rounded-md px-3.5 py-2 bg-blue-600 hover:bg-blue-500 text-white text-sm font-medium" %>
</div>

<div class="bg-white rounded-lg border border-gray-200 divide-y divide-gray-100">
  <% if @workflows.empty? %>
    <p class="p-6 text-gray-500">No workflows yet. Automate follow-ups when someone texts a keyword, gets tagged, submits a form, RSVPs, or donates.</p>
  <% end %>
  <% @workflows.each do |workflow| %>
    <div class="p-4 flex items-center justify-between">
      <div>
        <%= link_to workflow.name, workflow, class: "font-medium text-blue-700 hover:underline" %>
        <div class="text-sm text-gray-500">
          When <%= workflow.trigger.humanize.downcase %><%= " (#{workflow.trigger_param})" if workflow.trigger_param.present? %>
          · <%= pluralize(workflow.workflow_steps.size, "step") %>
        </div>
      </div>
      <span class="text-xs rounded-full px-2 py-0.5 <%= workflow.enabled? ? 'bg-green-50 text-green-700' : 'bg-gray-100 text-gray-500' %>"><%= workflow.enabled? ? "enabled" : "disabled" %></span>
    </div>
  <% end %>
</div>

<%= render "shared/flash" %>

<div class="flex items-center justify-between mb-4">
  <h1 class="font-bold text-3xl">Workflows</h1>
  <%= link_to "New workflow", new_workflow_path, class: "rounded-md px-3.5 py-2 bg-indigo-600 hover:bg-indigo-500 text-white text-sm font-medium" %>
</div>

<div class="bg-slate-800/60 rounded-lg border border-slate-700/70 divide-y divide-slate-700/60">
  <% if @workflows.empty? %>
    <p class="p-6 text-slate-400">No workflows yet. Automate follow-ups when someone texts a keyword, gets tagged, submits a form, RSVPs, or donates.</p>
  <% end %>
  <% @workflows.each do |workflow| %>
    <div class="p-4 flex items-center justify-between">
      <div>
        <%= link_to workflow.name, workflow, class: "font-medium text-indigo-400 hover:underline" %>
        <div class="text-sm text-slate-400">
          When <%= workflow.trigger.humanize.downcase %><%= " (#{workflow.trigger_param})" if workflow.trigger_param.present? %>
          · <%= pluralize(workflow.workflow_steps.size, "step") %>
        </div>
      </div>
      <span class="text-xs rounded-full px-2 py-0.5 <%= workflow.enabled? ? 'bg-green-500/10 text-green-400' : 'bg-slate-700 text-slate-400' %>"><%= workflow.enabled? ? "enabled" : "disabled" %></span>
    </div>
  <% end %>
</div>

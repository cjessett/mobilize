<%= form_with model: workflow, class: "contents", data: { controller: "steps" } do |form| %>
  <% if workflow.errors.any? %>
    <p class="py-2 px-3 bg-red-50 mb-5 text-red-500 font-medium rounded-lg inline-block"><%= workflow.errors.full_messages.to_sentence %></p>
  <% end %>

  <div class="my-5">
    <%= form.label :name, class: "block text-sm font-medium text-gray-700" %>
    <%= form.text_field :name, required: true, class: "block shadow-sm rounded-md border border-gray-400 px-3 py-2 mt-2 w-full md:w-1/2 bg-white" %>
  </div>

  <div class="my-5 flex gap-4 items-end flex-wrap">
    <div>
      <%= form.label :trigger, "When", class: "block text-sm font-medium text-gray-700" %>
      <%= form.select :trigger,
            [ [ "Keyword received", "keyword_received" ], [ "Tag added", "tag_added" ], [ "Form submitted", "form_submitted" ], [ "Event RSVP", "rsvp_created" ], [ "Donation received", "donation_created" ] ],
            {}, { class: "block shadow-sm rounded-md border border-gray-300 px-3 py-2 mt-2 bg-white" } %>
    </div>
    <div>
      <%= form.label :trigger_param, "Matching (keyword/tag/form id — blank = any)", class: "block text-sm font-medium text-gray-700" %>
      <%= form.text_field :trigger_param, class: "block shadow-sm rounded-md border border-gray-300 px-3 py-2 mt-2 bg-white" %>
    </div>
    <div>
      <label class="block text-sm font-medium text-gray-700">Scope</label>
      <%= select_tag "workflow[access_scope_gid]",
            options_for_select(
              [ [ "Organization-wide", "organization" ] ] + current_organization.chapters.order(:name).map { |c| [ c.name, "chapter-#{c.id}" ] },
              workflow.access_scope.is_a?(Chapter) ? "chapter-#{workflow.access_scope_id}" : "organization"
            ),
            class: "block shadow-sm rounded-md border border-gray-300 px-3 py-2 mt-2 bg-white" %>
    </div>
  </div>

  <h3 class="font-semibold text-sm text-gray-700 mb-2">Steps (run in order)</h3>
  <div data-steps-target="rows" class="space-y-2">
    <% workflow.workflow_steps.each do |step| %>
      <%= render "step_row", step: step.params.merge("action" => step.action) %>
    <% end %>
  </div>

  <template data-steps-target="template">
    <%= render "step_row", step: {} %>
  </template>

  <button type="button" data-action="steps#add" class="mt-3 text-sm text-blue-700 hover:underline cursor-pointer">+ Add step</button>

  <div class="mt-6">
    <%= form.submit workflow.persisted? ? "Save workflow" : "Create workflow", class: "rounded-md px-3.5 py-2.5 bg-blue-600 hover:bg-blue-500 text-white font-medium cursor-pointer" %>
  </div>
<% end %>

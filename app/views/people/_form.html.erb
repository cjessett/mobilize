<%= form_with model: person, class: "contents" do |form| %>
  <% if person.errors.any? %>
    <p class="py-2 px-3 bg-red-500/10 mt-4 text-red-600 dark:text-red-400 font-medium rounded-lg inline-block"><%= person.errors.full_messages.to_sentence %></p>
  <% end %>

  <%= form_card do %>
    <%= form_row "Name" do %>
      <div class="grid grid-cols-2 gap-4">
        <%= form.text_field :first_name, placeholder: "First name", class: ui_input %>
        <%= form.text_field :last_name, placeholder: "Last name", class: ui_input %>
      </div>
    <% end %>

    <%= form_row "Phone", hint: "Required if no email. Texts are sent to this number." do %>
      <%= form.telephone_field :phone, class: ui_input %>
    <% end %>

    <%= form_row "Email", hint: "Required if no phone." do %>
      <%= form.email_field :email, class: ui_input %>
    <% end %>

    <%= form_row "Address", hint: "Zip code assigns the primary chapter automatically." do %>
      <div class="space-y-3">
        <%= form.text_field :address, placeholder: "Street address", class: ui_input %>
        <div class="grid grid-cols-3 gap-3">
          <%= form.text_field :city, placeholder: "City", class: ui_input %>
          <%= form.text_field :state, placeholder: "State", class: ui_input %>
          <%= form.text_field :zip_code, placeholder: "Zip", class: ui_input %>
        </div>
      </div>
    <% end %>

    <%= form_row "Tags", hint: "Comma separated. New tags are created automatically." do %>
      <%= form.text_field :tag_list, value: person.persisted? ? person.tag_list : "", class: ui_input %>
    <% end %>

    <% if person.persisted? %>
      <%= form_row "Primary chapter" do %>
        <%= form.select :primary_chapter_id, current_organization.chapters.order(:name).map { |c| [ c.name, c.id ] }, { selected: person.primary_chapter&.id }, { class: ui_input } %>
      <% end %>
    <% end %>

    <% current_organization.custom_fields.order(:label).each do |field| %>
      <%= form_row field.label do %>
        <%= text_field_tag "person[custom_field_values][#{field.key}]", person.custom_field_values[field.key], class: ui_input %>
      <% end %>
    <% end %>

    <%= form_row "Calling" do %>
      <label class="inline-flex items-center gap-2 text-sm text-gray-700 dark:text-slate-300 cursor-pointer">
        <%= form.check_box :do_not_call, class: "accent-indigo-500 h-4 w-4" %> Do not call this person
      </label>
    <% end %>

    <%= form_actions do %>
      <%= form.submit person.persisted? ? "Save Person" : "Create Person", class: "rounded-md px-4 py-2.5 bg-indigo-500 hover:bg-indigo-400 text-white font-medium cursor-pointer" %>
    <% end %>
  <% end %>
<% end %>

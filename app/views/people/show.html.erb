<%= render "shared/flash" %>

<div class="flex items-start justify-between mb-6">
  <div>
    <h1 class="font-bold text-3xl"><%= @person.name %></h1>
    <div class="text-slate-400 mt-1">
      <%= [ @person.phone, @person.email ].compact_blank.join(" · ") %>
    </div>
    <div class="mt-2 flex gap-2 flex-wrap">
      <% @person.chapter_memberships.includes(:chapter).each do |cm| %>
        <span class="text-xs bg-indigo-500/15 text-indigo-400 rounded-full px-2 py-0.5"><%= cm.chapter.name %><%= " (primary)" if cm.primary? %></span>
      <% end %>
      <% @person.tags.each do |tag| %>
        <span class="text-xs bg-slate-700 text-slate-300 rounded-full px-2 py-0.5"><%= tag.name %></span>
      <% end %>
      <% if @person.do_not_call? %><span class="text-xs bg-red-500/10 text-red-400 rounded-full px-2 py-0.5">Do not call</span><% end %>
      <% if @person.opted_out_sms? %><span class="text-xs bg-red-500/10 text-red-400 rounded-full px-2 py-0.5">SMS opt-out</span><% end %>
    </div>
  </div>
  <div class="flex gap-2">
    <% if @person.phone.present? %>
      <%= link_to "Text", conversation_path(@person), class: "rounded-md px-3.5 py-2 bg-indigo-600 hover:bg-indigo-500 text-white text-sm font-medium" %>
    <% end %>
    <%= link_to "Edit", edit_person_path(@person), class: "rounded-md px-3.5 py-2 border border-slate-600 bg-slate-800/60 hover:bg-slate-700 text-sm font-medium" %>
    <%= button_to "Delete", @person, method: :delete, data: { turbo_confirm: "Delete this person?" }, class: "rounded-md px-3.5 py-2 border border-red-500/40 text-red-400 bg-slate-800/60 hover:bg-red-500/10 text-sm font-medium cursor-pointer" %>
  </div>
</div>

<div class="grid md:grid-cols-3 gap-6">
  <div class="md:col-span-2">
    <h2 class="font-semibold text-lg mb-2">Activity</h2>
    <div class="bg-slate-800/60 rounded-lg border border-slate-700/70 divide-y divide-slate-700/60">
      <% if @activities.empty? %>
        <p class="p-4 text-slate-400 text-sm">No activity yet.</p>
      <% end %>
      <% @activities.each do |activity| %>
        <div class="p-4">
          <div class="text-xs text-slate-500"><%= activity.occurred_at.in_time_zone(current_organization.time_zone).strftime("%b %-d, %Y %l:%M %p") %></div>
          <div class="text-sm mt-1">
            <% case activity.kind %>
            <% when "note_added" %>
              <span class="font-medium">Note:</span> <%= activity.subject&.body %>
            <% else %>
              <span class="font-medium"><%= activity.kind.humanize %></span>
              <%= activity.data.map { |k, v| "#{k}: #{v}" }.join(", ") if activity.data.present? %>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  </div>

  <div>
    <h2 class="font-semibold text-lg mb-2">Add note</h2>
    <%= form_with model: [ @person, @note ], class: "contents" do |form| %>
      <%= form.text_area :body, rows: 3, class: "block shadow-sm rounded-md border border-slate-600 px-3 py-2 w-full bg-slate-800/60" %>
      <%= form.submit "Add note", class: "mt-2 rounded-md px-3.5 py-2 bg-indigo-600 hover:bg-indigo-500 text-white text-sm font-medium cursor-pointer" %>
    <% end %>

    <% if @person.custom_field_values.present? %>
      <h2 class="font-semibold text-lg mt-6 mb-2">Custom fields</h2>
      <div class="bg-slate-800/60 rounded-lg border border-slate-700/70 p-4 text-sm">
        <% current_organization.custom_fields.order(:label).each do |field| %>
          <div class="flex justify-between py-1">
            <span class="text-slate-400"><%= field.label %></span>
            <span><%= @person.custom_field_values[field.key] %></span>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>
</div>

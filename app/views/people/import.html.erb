<div class="mx-auto md:w-1/2 w-full">
  <%= render "shared/flash" %>
  <h1 class="font-bold text-3xl mb-4">Import people</h1>
  <p class="text-gray-500 mb-4 text-sm">
    Upload a CSV with headers: <code class="bg-gray-100 px-1 rounded">first_name,last_name,phone,email,zip_code,city,state,address,tags</code>.
    Existing people are matched by phone, then email, and updated.
  </p>

  <%= form_with url: import_people_path, method: :post, multipart: true, class: "contents" do |form| %>
    <%= form.file_field :file, accept: ".csv", class: "block w-full text-sm text-gray-600 border border-gray-300 rounded-md bg-white p-2" %>
    <%= form.submit "Import", class: "mt-4 rounded-md px-3.5 py-2.5 bg-blue-600 hover:bg-blue-500 text-white font-medium cursor-pointer" %>
  <% end %>
</div>

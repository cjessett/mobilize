<%= render "shared/flash" %>
<%= back_link "All People", people_path %>
<h1 class="font-bold text-3xl text-gray-900 dark:text-white mt-2">Import People</h1>

<%= form_with url: import_people_path, method: :post, multipart: true, class: "contents" do |form| %>
  <%= form_card do %>
    <%= form_row "CSV file", hint: "Headers: first_name,last_name,phone,email,zip_code,city,state,address,tags. Existing people are matched by phone, then email, and updated." do %>
      <%= form.file_field :file, accept: ".csv", class: "block w-full text-sm text-gray-700 dark:text-slate-300 rounded-md border border-gray-300 dark:border-slate-600 bg-gray-50 dark:bg-slate-900/70 p-2" %>
    <% end %>

    <%= form_actions do %>
      <%= form.submit "Import", class: "rounded-md px-4 py-2.5 bg-indigo-500 hover:bg-indigo-400 text-white font-medium cursor-pointer" %>
    <% end %>
  <% end %>
<% end %>

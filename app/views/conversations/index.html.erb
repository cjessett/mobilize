<%= render "shared/flash" %>

<h1 class="font-bold text-3xl mb-4">Inbox</h1>

<div class="bg-white rounded-lg border border-gray-200 divide-y divide-gray-100">
  <% if @conversations.empty? %>
    <p class="p-6 text-gray-500">No conversations yet. Send someone a text from their profile or a blast.</p>
  <% end %>
  <% @conversations.each do |person, last_message, at| %>
    <%= link_to conversation_path(person), class: "block p-4 hover:bg-gray-50" do %>
      <div class="flex items-center justify-between">
        <span class="font-medium text-gray-900"><%= person.name %></span>
        <span class="text-xs text-gray-400"><%= time_ago_in_words(at) %> ago</span>
      </div>
      <div class="text-sm text-gray-500 truncate mt-1">
        <span class="<%= last_message.direction == 'inbound' ? 'text-blue-700 font-medium' : '' %>">
          <%= last_message.direction == "inbound" ? "←" : "→" %> <%= last_message.body.truncate(100) %>
        </span>
      </div>
    <% end %>
  <% end %>
</div>

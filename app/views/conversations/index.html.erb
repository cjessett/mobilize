<%= render "shared/flash" %>

<h1 class="font-bold text-3xl mb-4">Inbox</h1>

<div class="bg-white dark:bg-slate-800/60 rounded-lg border border-gray-200 dark:border-slate-700/70 divide-y divide-gray-200 dark:divide-slate-700/60">
  <% if @conversations.empty? %>
    <p class="p-6 text-gray-500 dark:text-slate-400">No conversations yet. Send someone a text from their profile or a blast.</p>
  <% end %>
  <% @conversations.each do |person, last_message, at| %>
    <%= link_to conversation_path(person), class: "block p-4 hover:bg-gray-50 dark:hover:bg-slate-800" do %>
      <div class="flex items-center justify-between">
        <span class="font-medium text-gray-900 dark:text-slate-100"><%= person.name %></span>
        <span class="text-xs text-gray-400 dark:text-slate-500"><%= time_ago_in_words(at) %> ago</span>
      </div>
      <div class="text-sm text-gray-500 dark:text-slate-400 truncate mt-1">
        <span class="<%= last_message.direction == 'inbound' ? 'text-indigo-600 dark:text-indigo-400 font-medium' : '' %>">
          <%= last_message.direction == "inbound" ? "←" : "→" %> <%= last_message.body.truncate(100) %>
        </span>
      </div>
    <% end %>
  <% end %>
</div>

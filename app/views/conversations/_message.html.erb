<div class="<%= message.direction == 'inbound' ? 'self-start bg-gray-200 dark:bg-slate-700 text-gray-900 dark:text-slate-100' : 'self-end bg-indigo-600 text-white' %> rounded-2xl px-4 py-2 max-w-[75%]">
  <div class="text-sm whitespace-pre-wrap"><%= message.body %></div>
  <div class="text-[10px] mt-1 <%= message.direction == 'inbound' ? 'text-gray-400 dark:text-slate-500' : 'text-indigo-200' %>">
    <%= message.created_at.strftime("%b %-d %l:%M %p") %><%= " · #{message.status}" if message.direction == "outbound" %>
  </div>
</div>

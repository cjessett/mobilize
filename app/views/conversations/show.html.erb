<%= render "shared/flash" %>
<%= turbo_stream_from [ @person, :messages ] %>

<div class="mx-auto md:w-2/3 w-full">
  <div class="flex items-center justify-between mb-4">
    <div>
      <h1 class="font-bold text-2xl"><%= link_to @person.name, @person, class: "hover:underline" %></h1>
      <div class="text-sm text-gray-500 dark:text-slate-400"><%= @person.display_phone %> · <%= @person.primary_chapter&.name %></div>
    </div>
    <%= link_to "← Inbox", conversations_path, class: "text-sm text-indigo-600 dark:text-indigo-400 hover:underline" %>
  </div>

  <div id="conversation_messages" class="bg-white dark:bg-slate-800/60 rounded-lg border border-gray-200 dark:border-slate-700/70 p-4 space-y-3 min-h-64 max-h-[32rem] overflow-y-auto flex flex-col">
    <% @messages.each do |message| %>
      <%= render "conversations/message", message: message %>
    <% end %>
  </div>

  <% if @person.opted_out_sms? %>
    <p class="mt-3 text-sm text-red-600 dark:text-red-400">This person has opted out of SMS.</p>
  <% else %>
    <%= form_with url: reply_conversation_path(@person), method: :post, class: "mt-3 flex gap-2" do |form| %>
      <%= form.text_area "message[body]", rows: 2, placeholder: "Type a message…", class: "flex-1 shadow-sm rounded-md border border-gray-300 dark:border-slate-600 px-3 py-2 bg-white dark:bg-slate-800/60" %>
      <%= form.submit "Send", class: "self-end rounded-md px-4 py-2 bg-indigo-600 hover:bg-indigo-500 text-white font-medium cursor-pointer" %>
    <% end %>
  <% end %>
</div>

<%= render "shared/flash" %>
<%= turbo_stream_from [ @person, :messages ] %>

<div class="bg-white dark:bg-slate-800/40 rounded-xl border border-gray-200 dark:border-slate-700/70 flex overflow-hidden h-[calc(100vh-8.5rem)]">
  <%= render "list", active_person: @person %>

  <div class="flex-1 flex flex-col min-w-0">
    <div class="flex items-center gap-3 px-5 py-3 border-b border-gray-200 dark:border-slate-700/70">
      <span class="h-10 w-10 rounded-full bg-gray-200 dark:bg-slate-700 text-gray-700 dark:text-slate-300 flex items-center justify-center text-xs font-semibold uppercase shrink-0">
        <%= @person.name.split.map(&:first).first(2).join %>
      </span>
      <div class="min-w-0">
        <div class="font-semibold text-gray-900 dark:text-white truncate"><%= @person.name %></div>
        <div class="text-sm text-gray-500 dark:text-slate-400"><%= [ @person.display_phone, @person.primary_chapter&.name ].compact_blank.join(" · ") %></div>
      </div>
      <%= link_to @person, class: "ml-auto inline-flex items-center gap-1.5 rounded-md border border-gray-300 dark:border-slate-600 px-3 py-1.5 text-sm text-gray-700 dark:text-slate-300 hover:bg-gray-100 dark:hover:bg-slate-700" do %>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="h-4 w-4"><path stroke-linecap="round" stroke-linejoin="round" d="M11.25 11.25l.041-.02a.75.75 0 011.063.852l-.708 2.836a.75.75 0 001.063.853l.041-.021M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-9-3.75h.008v.008H12V8.25z"/></svg>
        Details
      <% end %>
    </div>

    <div id="conversation_messages" class="flex-1 overflow-y-auto p-5 space-y-3 flex flex-col">
      <% @messages.each do |message| %>
        <%= render "conversations/message", message: message %>
      <% end %>
    </div>

    <div class="border-t border-gray-200 dark:border-slate-700/70 p-4">
      <% if @person.opted_out_sms? %>
        <p class="text-sm text-red-600 dark:text-red-400">This person has opted out of SMS.</p>
      <% else %>
        <%= form_with url: reply_conversation_path(@person), method: :post, class: "flex items-end gap-3" do |form| %>
          <%= form.text_area "message[body]", rows: 2, placeholder: "Message…", class: "flex-1 rounded-lg border border-gray-300 dark:border-slate-600 bg-gray-50 dark:bg-slate-900/70 px-3 py-2 resize-none focus:outline-indigo-500" %>
          <%= form.submit "Send", class: "rounded-lg px-5 py-2.5 bg-indigo-500 hover:bg-indigo-400 text-white font-medium cursor-pointer" %>
        <% end %>
      <% end %>
    </div>
  </div>
</div>

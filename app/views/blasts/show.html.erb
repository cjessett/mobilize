<%= render "shared/flash" %>

<div class="mx-auto md:w-2/3 w-full">
  <div class="flex flex-wrap items-center justify-between gap-3 mb-2">
    <h1 class="font-bold text-3xl"><%= @blast.name %></h1>
    <span class="text-sm rounded-full px-3 py-1 <%= { 'draft' => 'bg-gray-200 dark:bg-slate-700 text-gray-700 dark:text-slate-300', 'scheduled' => 'bg-yellow-500/10 text-yellow-700 dark:text-yellow-300', 'sending' => 'bg-indigo-500/15 text-indigo-600 dark:text-indigo-400', 'sent' => 'bg-green-500/10 text-green-600 dark:text-green-400', 'failed' => 'bg-red-500/10 text-red-600 dark:text-red-400', 'canceled' => 'bg-gray-200 dark:bg-slate-700 text-gray-400 dark:text-slate-500' }[@blast.status] %>"><%= @blast.status %></span>
  </div>

  <div class="bg-white dark:bg-slate-800/60 rounded-lg border border-gray-200 dark:border-slate-700/70 p-4 mb-4">
    <div class="text-sm whitespace-pre-wrap"><%= @blast.body %></div>
    <div class="text-xs text-gray-400 dark:text-slate-500 mt-3">
      Audience: <%= @blast.segment&.name || "Everyone" %>
      · Scope: <%= @blast.org_scoped? ? "Organization-wide" : @blast.chapter.name %>
      · <%= pluralize(@recipient_count, @blast.editable? ? "recipient" : "message") %>
    </div>
  </div>

  <% if @stats.present? %>
    <div class="flex flex-wrap gap-3 mb-4">
      <% @stats.each do |status, count| %>
        <div class="bg-white dark:bg-slate-800/60 rounded-lg border border-gray-200 dark:border-slate-700/70 px-4 py-2 text-center">
          <div class="text-lg font-bold"><%= count %></div>
          <div class="text-xs text-gray-500 dark:text-slate-400"><%= status %></div>
        </div>
      <% end %>
    </div>
  <% end %>

  <% if @blast.editable? %>
    <div class="flex gap-2 items-end flex-wrap">
      <%= button_to "Send now", send_now_blast_path(@blast), method: :post, data: { turbo_confirm: "Send to #{@recipient_count} people now?" }, class: "rounded-md px-3.5 py-2.5 bg-indigo-600 hover:bg-indigo-500 text-white font-medium cursor-pointer" %>

      <%= form_with url: schedule_blast_path(@blast), method: :post, class: "flex flex-wrap gap-2 items-end" do |form| %>
        <div>
          <label class="block text-xs text-gray-500 dark:text-slate-400">Schedule for (<%= current_organization.time_zone %>)</label>
          <%= form.text_field :scheduled_at, placeholder: "Select time", data: { controller: "datepicker" }, class: "shadow-sm rounded-md border border-gray-300 dark:border-slate-600 px-3 py-2 mt-1 bg-gray-50 dark:bg-slate-900/70 w-64" %>
        </div>
        <%= form.submit "Schedule", class: "rounded-md px-3.5 py-2.5 border border-gray-300 dark:border-slate-600 bg-white dark:bg-slate-800/60 hover:bg-gray-100 dark:hover:bg-slate-700 font-medium cursor-pointer" %>
      <% end %>

      <% if @blast.scheduled? %>
        <%= button_to "Cancel schedule", cancel_blast_path(@blast), method: :post, class: "rounded-md px-3.5 py-2.5 border border-red-500/40 text-red-600 dark:text-red-400 bg-white dark:bg-slate-800/60 hover:bg-red-500/10 font-medium cursor-pointer" %>
      <% end %>
      <%= link_to "Edit", edit_blast_path(@blast), class: "rounded-md px-3.5 py-2.5 border border-gray-300 dark:border-slate-600 bg-white dark:bg-slate-800/60 hover:bg-gray-100 dark:hover:bg-slate-700 font-medium" %>
    </div>
  <% end %>
</div>

<%= form_with model: blast, class: "contents" do |form| %>
  <% if blast.errors.any? %>
    <p class="py-2 px-3 bg-red-500/10 mt-4 text-red-600 dark:text-red-400 font-medium rounded-lg inline-block"><%= blast.errors.full_messages.to_sentence %></p>
  <% end %>

  <%= form_card do %>
    <%= form_row "Blast name", hint: "Internal name, not shown to recipients." do %>
      <%= form.text_field :name, required: true, class: ui_input %>
    <% end %>

    <%= form_row "Message", hint: "Merge tags: {{first_name}}, {{last_name}}, {{name}}, {{chapter_name}}, or any custom field key." do %>
      <%= form.text_area :body, rows: 5, required: true, class: ui_input %>
    <% end %>

    <%= form_row "Audience" do %>
      <%= form.select :segment_id, [ [ "Everyone (all people)", "" ] ] + Segment.visible_to(current_membership).order(:name).map { |s| [ s.name, s.id ] }, {}, { class: ui_input } %>
    <% end %>

    <%= form_row "Scope", hint: "Chapter scope limits recipients to that chapter's people. Texts always send from each recipient's chapter number." do %>
      <%= select_tag "blast[access_scope_gid]",
            options_for_select(
              [ [ "Organization-wide", "organization" ] ] + current_organization.chapters.order(:name).map { |c| [ c.name, "chapter-#{c.id}" ] },
              blast.access_scope.is_a?(Chapter) ? "chapter-#{blast.access_scope_id}" : "organization"
            ),
            class: ui_input %>
    <% end %>

    <%= form_actions do %>
      <%= form.submit blast.persisted? ? "Save Blast" : "Create Blast", class: "rounded-md px-4 py-2.5 bg-indigo-500 hover:bg-indigo-400 text-white font-medium cursor-pointer" %>
    <% end %>
  <% end %>
<% end %>

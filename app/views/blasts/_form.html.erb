<%= form_with model: blast, class: "contents" do |form| %>
  <% if blast.errors.any? %>
    <p class="py-2 px-3 bg-red-500/10 mb-5 text-red-400 font-medium rounded-lg inline-block"><%= blast.errors.full_messages.to_sentence %></p>
  <% end %>

  <div class="my-5">
    <%= form.label :name, class: "block text-sm font-medium text-slate-300" %>
    <%= form.text_field :name, required: true, class: "block shadow-sm rounded-md border border-slate-600 px-3 py-2 mt-2 w-full md:w-1/2 bg-slate-800/60" %>
  </div>

  <div class="my-5">
    <%= form.label :body, "Message", class: "block text-sm font-medium text-slate-300" %>
    <%= form.text_area :body, rows: 5, required: true, class: "block shadow-sm rounded-md border border-slate-600 px-3 py-2 mt-2 w-full bg-slate-800/60" %>
    <p class="text-xs text-slate-500 mt-1">Merge tags: {{first_name}}, {{last_name}}, {{name}}, {{chapter_name}}, or any custom field key.</p>
  </div>

  <div class="my-5 flex gap-4">
    <div>
      <%= form.label :segment_id, "Audience", class: "block text-sm font-medium text-slate-300" %>
      <%= form.select :segment_id, [ [ "Everyone (all people)", "" ] ] + Segment.visible_to(current_membership).order(:name).map { |s| [ s.name, s.id ] }, {}, { class: "block shadow-sm rounded-md border border-slate-600 px-3 py-2 mt-2 bg-slate-800/60" } %>
    </div>
    <div>
      <label class="block text-sm font-medium text-slate-300">Scope</label>
      <%= select_tag "blast[access_scope_gid]",
            options_for_select(
              [ [ "Organization-wide", "organization" ] ] + current_organization.chapters.order(:name).map { |c| [ c.name, "chapter-#{c.id}" ] },
              blast.access_scope.is_a?(Chapter) ? "chapter-#{blast.access_scope_id}" : "organization"
            ),
            class: "block shadow-sm rounded-md border border-slate-600 px-3 py-2 mt-2 bg-slate-800/60" %>
      <p class="text-xs text-slate-500 mt-1">Chapter scope limits recipients to that chapter's people.</p>
    </div>
  </div>

  <%= form.submit blast.persisted? ? "Save blast" : "Create blast", class: "rounded-md px-3.5 py-2.5 bg-indigo-600 hover:bg-indigo-500 text-white font-medium cursor-pointer" %>
<% end %>

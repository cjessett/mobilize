<%= form_with model: blast, class: "contents" do |form| %>
  <% if blast.errors.any? %>
    <p class="py-2 px-3 bg-red-500/10 mt-4 text-red-600 dark:text-red-400 font-medium rounded-lg inline-block"><%= blast.errors.full_messages.to_sentence %></p>
  <% end %>

  <%= form_card do %>
    <%= form_row "Blast name", hint: "Internal name, not shown to recipients." do %>
      <%= form.text_field :name, required: true, class: ui_input %>
    <% end %>

    <%= form_row "Message", hint: "Merge tags: {{first_name}}, {{last_name}}, {{name}}, {{chapter_name}}, or any custom field key." do %>
      <div data-controller="sms-counter">
        <%= form.text_area :body, rows: 5, required: true, class: ui_input,
              data: { sms_counter_target: "input", action: "input->sms-counter#update" } %>
        <p class="text-xs text-gray-400 dark:text-slate-500 mt-1.5" data-sms-counter-target="output"></p>
      </div>
    <% end %>

    <%= form_row "Translations", hint: "Optional per-language versions. Recipients whose preferred language matches get that version; everyone else gets the default message." do %>
      <%= render "shared/language_variants", record: blast, param_name: "blast" %>
    <% end %>

    <%= form_row "Media", hint: "Optional images sent as MMS (up to 10, 5MB each)." do %>
      <%= form.file_field :media, multiple: true, accept: Blast::MEDIA_TYPES.join(","), class: "block w-full text-sm text-gray-500 dark:text-slate-400" %>
      <% if blast.media.attached? %>
        <div class="flex flex-wrap gap-2 mt-2">
          <% blast.media.each do |attachment| %>
            <%= image_tag attachment, class: "h-16 w-16 object-cover rounded-md border border-gray-200 dark:border-slate-700" %>
          <% end %>
        </div>
      <% end %>
    <% end %>

    <%= form_row "Audience" do %>
      <%= form.select :segment_id, [ [ "Everyone (all people)", "" ] ] + Segment.visible_to(current_membership).order(:name).map { |s| [ s.name, s.id ] }, {}, { class: ui_input } %>
    <% end %>

    <%= form_row "Scope", hint: "Chapter scope limits recipients to that chapter's people. Texts always send from each recipient's chapter number." do %>
      <%= select_tag "blast[access_scope_gid]",
            options_for_select(
              [ [ "Organization-wide", "organization" ] ] + current_organization.chapters.order(:name).map { |c| [ c.name, "chapter-#{c.id}" ] },
              blast.access_scope.is_a?(Chapter) ? "chapter-#{blast.access_scope_id}" : "organization"
            ),
            class: ui_input %>
    <% end %>

    <%= form_row "Texting hours", hint: "What to do with recipients whose local time is outside the organization's texting hours when the blast sends." do %>
      <%= form.select :texting_hours_mode,
            [ [ "Queue until their window opens", "queue" ], [ "Skip them", "skip" ], [ "Send anyway (override)", "override" ] ],
            {}, { class: ui_input } %>
    <% end %>

    <%= form_actions do %>
      <%= form.submit blast.persisted? ? "Save Blast" : "Create Blast", class: "rounded-md px-4 py-2.5 bg-indigo-500 hover:bg-indigo-400 text-white font-medium cursor-pointer" %>
    <% end %>
  <% end %>
<% end %>

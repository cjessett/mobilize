<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || @organization&.name || "Mobilize" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>
  <body class="bg-gray-50 min-h-screen">
    <header class="bg-white border-b border-gray-200">
      <div class="max-w-3xl mx-auto px-5 h-14 flex items-center">
        <span class="font-bold text-lg text-gray-900"><%= @organization&.name %></span>
      </div>
    </header>
    <main class="max-w-3xl mx-auto mt-8 px-5 pb-16">
      <% if alert = flash[:alert] %>
        <p class="py-2 px-3 bg-red-50 mb-5 text-red-500 font-medium rounded-lg inline-block"><%= alert %></p>
      <% end %>
      <% if notice = flash[:notice] %>
        <p class="py-2 px-3 bg-green-50 mb-5 text-green-600 font-medium rounded-lg inline-block"><%= notice %></p>
      <% end %>
      <%= yield %>
    </main>
  </body>
</html>

<!DOCTYPE html>
<html class="<%= "dark" if current_theme == "dark" %>">
  <head>
    <title><%= content_for(:title) || @organization&.name || "Mobilize" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>
  <body class="bg-gray-50 dark:bg-slate-900 text-gray-800 dark:text-slate-200 min-h-screen">
    <header class="bg-white dark:bg-slate-950 border-b border-gray-200 dark:border-slate-800">
      <div class="max-w-3xl mx-auto px-5 h-14 flex items-center gap-3">
        <span class="h-8 w-8 rounded-full bg-indigo-600 flex items-center justify-center text-white font-bold text-xs"><%= @organization&.name&.first %></span>
        <span class="font-bold text-lg text-gray-900 dark:text-white"><%= @organization&.name %></span>
      </div>
    </header>
    <main class="max-w-3xl mx-auto mt-8 px-5 pb-16">
      <% if alert = flash[:alert] %>
        <p class="py-2 px-3 bg-red-500/10 mb-5 text-red-600 dark:text-red-400 font-medium rounded-lg inline-block"><%= alert %></p>
      <% end %>
      <% if notice = flash[:notice] %>
        <p class="py-2 px-3 bg-green-500/10 mb-5 text-green-600 dark:text-green-400 font-medium rounded-lg inline-block"><%= notice %></p>
      <% end %>
      <%= yield %>
    </main>
  </body>
</html>

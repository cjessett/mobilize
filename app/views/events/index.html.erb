<%= render "shared/flash" %>

<div class="flex items-center justify-between mb-4">
  <h1 class="font-bold text-3xl">Events</h1>
  <%= link_to "New event", new_event_path, class: "rounded-md px-3.5 py-2 bg-indigo-600 hover:bg-indigo-500 text-white text-sm font-medium" %>
</div>

<h2 class="font-semibold text-lg mb-2">Upcoming</h2>
<div class="bg-white dark:bg-slate-800/60 rounded-lg border border-gray-200 dark:border-slate-700/70 divide-y divide-gray-200 dark:divide-slate-700/60 mb-6">
  <% if @upcoming.empty? %>
    <p class="p-6 text-gray-500 dark:text-slate-400">No upcoming events.</p>
  <% end %>
  <% @upcoming.each do |event| %>
    <div class="p-4 flex items-center justify-between">
      <div>
        <%= link_to event.title, event, class: "font-medium text-indigo-600 dark:text-indigo-400 hover:underline" %>
        <div class="text-sm text-gray-500 dark:text-slate-400">
          <%= event.starts_at.in_time_zone(current_organization.time_zone).strftime("%a %b %-d, %l:%M %p") %>
          <%= " · #{event.location}" if event.location.present? %>
        </div>
      </div>
      <span class="text-sm text-gray-400 dark:text-slate-500"><%= event.yes_rsvps.count %><%= "/#{event.capacity}" if event.capacity %> going</span>
    </div>
  <% end %>
</div>

<% if @past.any? %>
  <h2 class="font-semibold text-lg mb-2">Past</h2>
  <div class="bg-white dark:bg-slate-800/60 rounded-lg border border-gray-200 dark:border-slate-700/70 divide-y divide-gray-200 dark:divide-slate-700/60">
    <% @past.each do |event| %>
      <div class="p-4 flex items-center justify-between">
        <%= link_to event.title, event, class: "text-gray-700 dark:text-slate-300 hover:underline" %>
        <span class="text-sm text-gray-400 dark:text-slate-500"><%= event.starts_at.strftime("%b %-d, %Y") %> · <%= event.rsvps.where(attended: true).count %> attended</span>
      </div>
    <% end %>
  </div>
<% end %>

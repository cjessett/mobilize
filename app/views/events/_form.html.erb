<%= form_with model: event, class: "contents" do |form| %>
  <% if event.errors.any? %>
    <p class="py-2 px-3 bg-red-500/10 mt-4 text-red-600 dark:text-red-400 font-medium rounded-lg inline-block"><%= event.errors.full_messages.to_sentence %></p>
  <% end %>

  <%= form_card do %>
    <%= form_row "Event title", hint: "Maximum 65 characters" do %>
      <%= form.text_field :title, required: true, maxlength: 65, class: ui_input %>
    <% end %>

    <%= form_row "Event type" do %>
      <div class="space-y-4">
        <% { "in_person" => [ "In-Person", "Physical event with a real physical address." ],
             "virtual" => [ "Virtual", "Digital event with a web address." ],
             "hybrid" => [ "Hybrid", "Physical event with a virtual option." ] }.each do |value, (label, description)| %>
          <label class="flex items-start gap-3 cursor-pointer">
            <%= form.radio_button :event_type, value, class: "mt-1 h-5 w-5 accent-indigo-500" %>
            <span>
              <span class="block font-medium text-gray-900 dark:text-white"><%= label %></span>
              <span class="block text-sm text-gray-400 dark:text-slate-500"><%= description %></span>
            </span>
          </label>
        <% end %>
      </div>
    <% end %>

    <%= form_row "Begins at", hint: "Shown in #{current_organization.time_zone}." do %>
      <%= form.datetime_local_field :starts_at, required: true, value: event.starts_at&.in_time_zone(current_organization.time_zone)&.strftime("%Y-%m-%dT%H:%M"), class: ui_input %>
    <% end %>

    <%= form_row "Ends at" do %>
      <%= form.datetime_local_field :ends_at, value: event.ends_at&.in_time_zone(current_organization.time_zone)&.strftime("%Y-%m-%dT%H:%M"), class: ui_input %>
    <% end %>

    <%= form_row "Location", hint: "Street address for in-person and hybrid events." do %>
      <%= form.text_field :location, class: ui_input %>
    <% end %>

    <%= form_row "Virtual link", hint: "Zoom or stream URL for virtual and hybrid events." do %>
      <%= form.url_field :virtual_url, class: ui_input %>
    <% end %>

    <%= form_row "Capacity", hint: "RSVPs beyond capacity join the waitlist." do %>
      <%= form.number_field :capacity, min: 1, class: "#{ui_input} md:w-40" %>
    <% end %>

    <%= form_row "Description" do %>
      <%= form.text_area :description, rows: 4, class: ui_input %>
    <% end %>

    <%= form_row "Scope" do %>
      <%= select_tag "event[access_scope_gid]",
            options_for_select(
              [ [ "Organization-wide", "organization" ] ] + current_organization.chapters.order(:name).map { |c| [ c.name, "chapter-#{c.id}" ] },
              event.access_scope.is_a?(Chapter) ? "chapter-#{event.access_scope_id}" : "organization"
            ),
            class: ui_input %>
    <% end %>

    <%= form_actions do %>
      <%= form.submit event.persisted? ? "Save Event" : "Create Event", class: "rounded-md px-4 py-2.5 bg-indigo-500 hover:bg-indigo-400 text-white font-medium cursor-pointer" %>
    <% end %>
  <% end %>
<% end %>

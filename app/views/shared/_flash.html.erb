<% if alert = flash[:alert] %>
  <p class="py-2 px-3 bg-red-500/10 mb-5 text-red-400 font-medium rounded-lg inline-block" id="alert"><%= alert %></p>
<% end %>

<% if notice = flash[:notice] %>
  <p class="py-2 px-3 bg-green-500/10 mb-5 text-green-400 font-medium rounded-lg inline-block" id="notice"><%= notice %></p>
<% end %>

<h1 class="font-bold text-3xl"><%= @form.title %></h1>

<% if @form.description.present? %>
  <div class="mt-3 text-gray-700 dark:text-slate-300 whitespace-pre-wrap"><%= @form.description %></div>
<% end %>

<% if @form.petition? %>
  <div class="bg-white dark:bg-slate-800/60 rounded-lg border border-gray-200 dark:border-slate-700/70 p-4 mt-4">
    <div class="flex justify-between text-sm mb-1">
      <span class="font-medium"><%= @form.signature_count %> signed</span>
      <% if @form.goal %><span class="text-gray-500 dark:text-slate-400">Goal: <%= @form.goal %></span><% end %>
    </div>
    <% if @form.goal %>
      <div class="bg-gray-200 dark:bg-slate-700 rounded-full h-2">
        <div class="bg-indigo-600 rounded-full h-2" style="width: <%= [ (@form.signature_count * 100.0 / @form.goal), 100 ].min.round %>%"></div>
      </div>
    <% end %>
  </div>
<% end %>

<div class="bg-white dark:bg-slate-800/60 rounded-lg border border-gray-200 dark:border-slate-700/70 p-5 mt-6">
  <h2 class="font-semibold text-lg mb-3"><%= @form.petition? ? "Add your name" : "Sign up" %></h2>
  <%= form_with url: public_submit_form_path(@organization.slug, @form.slug), method: :post, class: "contents" do |f| %>
    <%= hidden_field_tag :mb, params[:mb] if params[:mb].present? %>
    <div class="grid md:grid-cols-2 gap-3">
      <% @form.form_fields.each do |field| %>
        <div>
          <label class="block text-sm font-medium text-gray-700 dark:text-slate-300"><%= field.label %><%= " *" if field.required? %></label>
          <%= text_field_tag field.key, nil, required: field.required?, class: "block shadow-sm rounded-md border border-gray-300 dark:border-slate-600 px-3 py-2 mt-1 w-full bg-white dark:bg-slate-800/60" %>
        </div>
      <% end %>
    </div>
    <%= f.submit @form.petition? ? "Sign the petition" : "Submit", class: "mt-4 rounded-md px-4 py-2.5 bg-indigo-600 hover:bg-indigo-500 text-white font-medium cursor-pointer" %>
  <% end %>
</div>

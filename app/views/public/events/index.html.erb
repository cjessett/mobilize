<h1 class="font-bold text-3xl mb-6">Upcoming events</h1>

<div class="space-y-4">
  <% if @events.empty? %>
    <p class="text-gray-500">No upcoming events.</p>
  <% end %>
  <% @events.each do |event| %>
    <%= link_to public_event_path(@organization.slug, event), class: "block bg-white rounded-lg border border-gray-200 p-5 hover:border-blue-300" do %>
      <div class="font-semibold text-lg text-gray-900"><%= event.title %></div>
      <div class="text-sm text-gray-500 mt-1">
        <%= event.starts_at.in_time_zone(@organization.time_zone).strftime("%A %b %-d, %l:%M %p") %>
        <%= " · #{event.location}" if event.location.present? %>
      </div>
    <% end %>
  <% end %>
</div>

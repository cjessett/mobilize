<%= link_to "← All events", public_events_path(@organization.slug), class: "text-sm text-indigo-600 dark:text-indigo-400 hover:underline" %>

<h1 class="font-bold text-3xl mt-2"><%= @event.title %></h1>
<div class="text-gray-500 dark:text-slate-400 mt-1">
  <%= @event.starts_at.in_time_zone(@event.display_time_zone).strftime("%A %b %-d, %Y %l:%M %p %Z") %>
  <%= " · #{@event.location}" if @event.location.present? %>
</div>
<div class="mt-1">
  <%= link_to "Add to calendar", calendar_public_event_path(@organization.slug, @event), class: "text-sm text-indigo-600 dark:text-indigo-400 hover:underline" %>
</div>

<% if @event.description.present? %>
  <div class="mt-4 text-gray-700 dark:text-slate-300 whitespace-pre-wrap"><%= @event.description %></div>
<% end %>

<% if @sessions.size > 1 %>
  <div class="bg-white dark:bg-slate-800/60 rounded-lg border border-gray-200 dark:border-slate-700/70 p-5 mt-6">
    <h2 class="font-semibold text-lg mb-2">Sessions</h2>
    <ul class="space-y-1 text-sm text-gray-700 dark:text-slate-300">
      <% @sessions.each do |session| %>
        <li>
          <%= session.starts_at.in_time_zone(@event.display_time_zone).strftime("%A %b %-d, %l:%M %p") %>
          <%= " — #{session.title}" if session.title.present? %>
          <%= " · #{session.location}" if session.location.present? %>
          <%= " · full (waitlist)" if session.full? %>
        </li>
      <% end %>
    </ul>
  </div>
<% end %>

<div class="bg-white dark:bg-slate-800/60 rounded-lg border border-gray-200 dark:border-slate-700/70 p-5 mt-6">
  <h2 class="font-semibold text-lg mb-1">RSVP</h2>
  <% if @event.full? && @sessions.size == 1 %>
    <p class="text-sm text-yellow-700 dark:text-yellow-300 mb-3">This event is at capacity — "yes" RSVPs join the waitlist.</p>
  <% end %>
  <%= form_with url: rsvp_public_event_path(@organization.slug, @event), method: :post, class: "contents" do |form| %>
    <div class="grid md:grid-cols-2 gap-3 mt-3">
      <%= form.text_field :first_name, placeholder: "First name", required: true, class: "shadow-sm rounded-md border border-gray-300 dark:border-slate-600 px-3 py-2 bg-white dark:bg-slate-800/60" %>
      <%= form.text_field :last_name, placeholder: "Last name", class: "shadow-sm rounded-md border border-gray-300 dark:border-slate-600 px-3 py-2 bg-white dark:bg-slate-800/60" %>
      <%= form.telephone_field :phone, placeholder: "Phone", class: "shadow-sm rounded-md border border-gray-300 dark:border-slate-600 px-3 py-2 bg-white dark:bg-slate-800/60" %>
      <%= form.email_field :email, placeholder: "Email", class: "shadow-sm rounded-md border border-gray-300 dark:border-slate-600 px-3 py-2 bg-white dark:bg-slate-800/60" %>
      <%= form.text_field :zip_code, placeholder: "Zip code", class: "shadow-sm rounded-md border border-gray-300 dark:border-slate-600 px-3 py-2 bg-white dark:bg-slate-800/60" %>
      <% if @sessions.size > 1 %>
        <%= form.select :session_id, @sessions.map { |s| [ s.display_title, s.id ] }, {}, { class: "shadow-sm rounded-md border border-gray-300 dark:border-slate-600 px-3 py-2 bg-white dark:bg-slate-800/60" } %>
      <% end %>
    </div>
    <p class="text-xs text-gray-400 dark:text-slate-500 mt-2">Provide a phone number or email. By RSVPing with a phone number you agree to receive event reminders by text.</p>
    <div class="flex gap-2 mt-3 flex-wrap">
      <button type="submit" name="status" value="yes" class="rounded-md px-4 py-2.5 bg-indigo-600 hover:bg-indigo-500 text-white font-medium cursor-pointer">I'll be there</button>
      <button type="submit" name="status" value="maybe" class="rounded-md px-4 py-2.5 border border-gray-300 dark:border-slate-600 bg-white dark:bg-slate-800/60 hover:bg-gray-100 dark:hover:bg-slate-700 font-medium cursor-pointer">Maybe</button>
      <button type="submit" name="status" value="no" class="rounded-md px-4 py-2.5 border border-gray-300 dark:border-slate-600 bg-white dark:bg-slate-800/60 hover:bg-gray-100 dark:hover:bg-slate-700 font-medium cursor-pointer">Can't make it</button>
    </div>
  <% end %>
</div>

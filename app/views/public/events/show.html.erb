<%= link_to "← All events", public_events_path(@organization.slug), class: "text-sm text-indigo-400 hover:underline" %>

<h1 class="font-bold text-3xl mt-2"><%= @event.title %></h1>
<div class="text-slate-400 mt-1">
  <%= @event.starts_at.in_time_zone(@organization.time_zone).strftime("%A %b %-d, %Y %l:%M %p %Z") %>
  <%= " · #{@event.location}" if @event.location.present? %>
</div>

<% if @event.description.present? %>
  <div class="mt-4 text-slate-300 whitespace-pre-wrap"><%= @event.description %></div>
<% end %>

<div class="bg-slate-800/60 rounded-lg border border-slate-700/70 p-5 mt-6">
  <h2 class="font-semibold text-lg mb-1">RSVP</h2>
  <% if @event.full? %>
    <p class="text-sm text-yellow-300 mb-3">This event is at capacity — you'll be added to the waitlist.</p>
  <% end %>
  <%= form_with url: rsvp_public_event_path(@organization.slug, @event), method: :post, class: "contents" do |form| %>
    <div class="grid md:grid-cols-2 gap-3 mt-3">
      <%= form.text_field :first_name, placeholder: "First name", required: true, class: "shadow-sm rounded-md border border-slate-600 px-3 py-2 bg-slate-800/60" %>
      <%= form.text_field :last_name, placeholder: "Last name", class: "shadow-sm rounded-md border border-slate-600 px-3 py-2 bg-slate-800/60" %>
      <%= form.telephone_field :phone, placeholder: "Phone", class: "shadow-sm rounded-md border border-slate-600 px-3 py-2 bg-slate-800/60" %>
      <%= form.email_field :email, placeholder: "Email", class: "shadow-sm rounded-md border border-slate-600 px-3 py-2 bg-slate-800/60" %>
      <%= form.text_field :zip_code, placeholder: "Zip code", class: "shadow-sm rounded-md border border-slate-600 px-3 py-2 bg-slate-800/60" %>
    </div>
    <p class="text-xs text-slate-500 mt-2">Provide a phone number or email. By RSVPing with a phone number you agree to receive event reminders by text.</p>
    <%= form.submit @event.full? ? "Join waitlist" : "RSVP", class: "mt-3 rounded-md px-4 py-2.5 bg-indigo-600 hover:bg-indigo-500 text-white font-medium cursor-pointer" %>
  <% end %>
</div>

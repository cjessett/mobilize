<%= form_with model: template, class: "contents" do |form| %>
  <% if template.errors.any? %>
    <p class="py-2 px-3 bg-red-500/10 mt-4 text-red-600 dark:text-red-400 font-medium rounded-lg inline-block"><%= template.errors.full_messages.to_sentence %></p>
  <% end %>

  <%= form_card do %>
    <%= form_row "Template name" do %>
      <%= form.text_field :name, required: true, class: ui_input %>
    <% end %>

    <%= form_row "Message", hint: "Merge tags: {{first_name}}, {{last_name}}, {{name}}, {{chapter_name}}." do %>
      <div data-controller="sms-counter">
        <%= form.text_area :body, rows: 5, required: true, class: ui_input,
              data: { sms_counter_target: "input", action: "input->sms-counter#update" } %>
        <p class="text-xs text-gray-400 dark:text-slate-500 mt-1.5" data-sms-counter-target="output"></p>
      </div>
    <% end %>

    <%= form_row "Translations", hint: "Optional per-language versions of the message." do %>
      <%= render "shared/language_variants", record: template, param_name: "sms_template" %>
    <% end %>

    <%= form_row "Event", hint: "Event templates only appear when working in that event's context. Leave blank for a global template." do %>
      <%= form.collection_select :event_id, current_organization.events.order(starts_at: :desc), :id, :title, { include_blank: "Global (all contexts)" }, { class: ui_input } %>
    <% end %>

    <%= form_actions do %>
      <%= form.submit template.persisted? ? "Save Template" : "Create Template", class: "rounded-md px-4 py-2.5 bg-indigo-500 hover:bg-indigo-400 text-white font-medium cursor-pointer" %>
    <% end %>
  <% end %>
<% end %>

<%= form_with model: template, class: "contents" do |form| %>
  <% if template.errors.any? %>
    <p class="py-2 px-3 bg-red-500/10 mb-5 text-red-400 font-medium rounded-lg inline-block"><%= template.errors.full_messages.to_sentence %></p>
  <% end %>
  <div class="my-5">
    <%= form.label :name, class: "block text-sm font-medium text-slate-300" %>
    <%= form.text_field :name, required: true, class: "block shadow-sm rounded-md border border-slate-600 px-3 py-2 mt-2 w-full md:w-1/2 bg-slate-800/60" %>
  </div>
  <div class="my-5">
    <%= form.label :body, class: "block text-sm font-medium text-slate-300" %>
    <%= form.text_area :body, rows: 5, required: true, class: "block shadow-sm rounded-md border border-slate-600 px-3 py-2 mt-2 w-full bg-slate-800/60" %>
    <p class="text-xs text-slate-500 mt-1">Merge tags: {{first_name}}, {{last_name}}, {{name}}, {{chapter_name}}.</p>
  </div>
  <%= form.submit template.persisted? ? "Save" : "Create template", class: "rounded-md px-3.5 py-2.5 bg-indigo-600 hover:bg-indigo-500 text-white font-medium cursor-pointer" %>
<% end %>

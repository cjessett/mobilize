<%= render "shared/flash" %>

<div class="flex flex-wrap items-center justify-between gap-3 mb-6">
  <h1 class="font-bold text-3xl text-gray-900 dark:text-white">SMS Templates</h1>
  <%= link_to "Create New Template", new_sms_template_path, class: "rounded-md px-4 py-2 bg-indigo-600 hover:bg-indigo-500 text-white text-sm font-medium" %>
</div>

<div class="bg-white dark:bg-slate-800/40 rounded-xl border border-gray-200 dark:border-slate-700/70">
  <div class="overflow-x-auto">
  <table class="w-full text-left min-w-[40rem]">
    <thead>
      <tr class="text-xs uppercase tracking-wider text-gray-400 dark:text-slate-500">
        <th class="px-6 py-4 font-semibold">Name</th>
        <th class="px-4 py-4 font-semibold">Message</th>
        <th class="px-4 py-4 font-semibold text-right pr-6">Actions</th>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-200 dark:divide-slate-700/60">
      <% if @templates.empty? %>
        <tr><td colspan="3" class="px-6 py-8 text-gray-500 dark:text-slate-400">No templates yet.</td></tr>
      <% end %>
      <% @templates.each do |template| %>
        <tr class="hover:bg-gray-50 dark:hover:bg-slate-800">
          <td class="px-6 py-4 font-medium text-gray-900 dark:text-white"><%= template.name %></td>
          <td class="px-4 py-4 text-sm text-gray-500 dark:text-slate-400 max-w-md truncate"><%= template.body.truncate(100) %></td>
          <td class="px-4 py-4 pr-6">
            <div class="flex gap-3 justify-end">
              <%= link_to "Use in blast", new_blast_path(template_id: template.id), class: "text-sm text-indigo-600 dark:text-indigo-400 hover:underline" %>
              <%= link_to "Edit", edit_sms_template_path(template), class: "text-sm text-indigo-600 dark:text-indigo-400 hover:underline" %>
              <%= button_to "Delete", sms_template_path(template), method: :delete, data: { turbo_confirm: "Delete this template?" }, class: "text-sm text-red-600 dark:text-red-400 hover:underline cursor-pointer" %>
            </div>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
  </div>
</div>

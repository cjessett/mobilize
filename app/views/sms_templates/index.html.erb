<%= render "shared/flash" %>

<div class="flex items-center justify-between mb-4">
  <h1 class="font-bold text-3xl">SMS templates</h1>
  <%= link_to "New template", new_sms_template_path, class: "rounded-md px-3.5 py-2 bg-blue-600 hover:bg-blue-500 text-white text-sm font-medium" %>
</div>

<div class="bg-white rounded-lg border border-gray-200 divide-y divide-gray-100">
  <% if @templates.empty? %>
    <p class="p-6 text-gray-500">No templates yet.</p>
  <% end %>
  <% @templates.each do |template| %>
    <div class="p-4 flex items-center justify-between">
      <div>
        <div class="font-medium"><%= template.name %></div>
        <div class="text-sm text-gray-500 truncate max-w-xl"><%= template.body.truncate(120) %></div>
      </div>
      <div class="flex gap-3">
        <%= link_to "Use in blast", new_blast_path(template_id: template.id), class: "text-sm text-blue-700 hover:underline" %>
        <%= link_to "Edit", edit_sms_template_path(template), class: "text-sm text-blue-700 hover:underline" %>
        <%= button_to "Delete", sms_template_path(template), method: :delete, data: { turbo_confirm: "Delete this template?" }, class: "text-sm text-red-600 hover:underline cursor-pointer" %>
      </div>
    </div>
  <% end %>
</div>

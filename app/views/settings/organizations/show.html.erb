<%= render "shared/flash" %>

<h1 class="font-bold text-3xl text-gray-900 dark:text-white mb-6">Settings</h1>

<div class="bg-white dark:bg-slate-800/40 rounded-xl border border-gray-200 dark:border-slate-700/70">
  <%= render "settings/nav" %>

  <div class="divide-y divide-gray-100 dark:divide-slate-700/40">
    <div class="flex items-center justify-between gap-4 px-4 md:px-6 py-4">
      <div>
        <p class="text-sm font-medium text-gray-900 dark:text-white">Instagram</p>
        <% if @organization.instagram_username.present? %>
          <p class="text-sm text-gray-500 dark:text-slate-400">Connected as <span class="font-medium text-gray-700 dark:text-slate-200">@<%= @organization.instagram_username %></span></p>
        <% else %>
          <p class="text-sm text-gray-500 dark:text-slate-400">Connect to enable DM-from-comment campaigns and follow automations.</p>
        <% end %>
      </div>
      <% if @organization.instagram_username.present? %>
        <%= button_to "Disconnect", disconnect_settings_instagram_index_path, method: :delete,
              class: "rounded-md px-3 py-1.5 text-sm border border-red-300 dark:border-red-700 text-red-600 dark:text-red-400 hover:bg-red-50 dark:hover:bg-red-900/20 cursor-pointer" %>
      <% else %>
        <%= link_to "Connect Instagram", connect_settings_instagram_index_path,
              class: "rounded-md px-3 py-1.5 text-sm bg-indigo-500 hover:bg-indigo-400 text-white font-medium" %>
      <% end %>
    </div>
  </div>

  <%= form_with model: @organization, url: settings_organization_path, method: :patch, class: "contents" do |form| %>
    <div class="divide-y divide-gray-100 dark:divide-slate-700/40">
      <%= form_row "Organization name" do %>
        <%= form.text_field :name, required: true, class: ui_input %>
      <% end %>

      <%= form_row "Public URL slug", hint: "Used for public pages: /o/#{@organization.slug}/..." do %>
        <%= form.text_field :slug, required: true, class: ui_input %>
      <% end %>

      <%= form_row "Time zone", hint: "Scheduling and event times are shown in this zone." do %>
        <%= form.time_zone_select :time_zone, ActiveSupport::TimeZone.us_zones, {}, { class: ui_input } %>
      <% end %>

      <%= form_row "Texting hours", hint: "Texts outside this window are held until it next opens, based on each recipient's state (approximate) or the org time zone." do %>
        <% hour_options = (0..23).map { |h| [ Time.zone.parse("#{h}:00").strftime("%-l:00 %p"), h ] } %>
        <div class="flex items-center gap-2">
          <%= form.select :texting_hours_start, hour_options, {}, { class: ui_input + " !w-36" } %>
          <span class="text-sm text-gray-500 dark:text-slate-400">to</span>
          <%= form.select :texting_hours_end, hour_options, {}, { class: ui_input + " !w-36" } %>
        </div>
        <div class="flex flex-wrap gap-3 mt-3">
          <% Date::ABBR_DAYNAMES.each_with_index do |day, wday| %>
            <label class="flex items-center gap-1.5 text-sm text-gray-700 dark:text-slate-300">
              <%= check_box_tag "organization[texting_days][]", wday, Array(@organization.texting_days).map(&:to_i).include?(wday) %>
              <%= day %>
            </label>
          <% end %>
        </div>
      <% end %>

      <%= form_actions do %>
        <%= form.submit "Save Settings", class: "rounded-md px-4 py-2.5 bg-indigo-500 hover:bg-indigo-400 text-white font-medium cursor-pointer" %>
      <% end %>
    </div>
  <% end %>
</div>

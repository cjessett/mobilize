<%= form_with model: chapter, url: chapter.persisted? ? settings_chapter_path(chapter) : settings_chapters_path, class: "contents" do |form| %>
  <% if chapter.errors.any? %>
    <p class="py-2 px-3 bg-red-500/10 mt-4 text-red-600 dark:text-red-400 font-medium rounded-lg inline-block"><%= chapter.errors.full_messages.to_sentence %></p>
  <% end %>

  <%= form_card do %>
    <%= form_row "Chapter name" do %>
      <%= form.text_field :name, required: true, class: ui_input %>
    <% end %>

    <%= form_row "Phone number", hint: "Texts to this chapter's people are sent from this number." do %>
      <% if chapter.phone_number.present? %>
        <p class="text-lg font-medium text-gray-900 dark:text-white"><%= format_phone(chapter.phone_number) %>
          <% if chapter.provisioned_at.present? %><%= status_pill "Provisioned", :green %><% end %>
        </p>
      <% else %>
        <p class="text-sm text-gray-500 dark:text-slate-400">No number yet. Provision one below by area code.</p>
      <% end %>
    <% end %>

    <%= form_row "Zip codes", hint: "People with these zip codes are automatically assigned to this chapter." do %>
      <%= form.text_area :zip_codes_list, value: chapter.persisted? ? chapter.zip_codes_list.join(", ") : "", rows: 3, placeholder: "60601, 60602, 60603", class: ui_input %>
    <% end %>

    <%= form_actions do %>
      <%= form.submit chapter.persisted? ? "Save Chapter" : "Create Chapter", class: "rounded-md px-4 py-2.5 bg-indigo-500 hover:bg-indigo-400 text-white font-medium cursor-pointer" %>
    <% end %>
  <% end %>
<% end %>

<div class="mx-auto md:w-2/3 w-full">
  <%= render "shared/flash" %>
  <h1 class="font-bold text-3xl mb-4">Settings</h1>
  <%= render "settings/nav" %>

  <div class="flex items-center justify-between mb-4">
    <h2 class="font-semibold text-xl">Members</h2>
    <%= link_to "Invite member", new_settings_member_path, class: "rounded-md px-3.5 py-2 bg-blue-600 hover:bg-blue-500 text-white text-sm font-medium" %>
  </div>

  <div class="bg-white rounded-lg border border-gray-200 divide-y divide-gray-100">
    <% @memberships.each do |membership| %>
      <div class="p-4 flex items-center justify-between">
        <div>
          <div class="font-medium"><%= membership.user.name %></div>
          <div class="text-sm text-gray-500">
            <%= membership.user.email_address %>
            · <span class="capitalize"><%= membership.role %></span>
            · <%= membership.org_wide? ? "All chapters" : membership.access_scope.name %>
          </div>
        </div>
        <% unless membership.user == Current.user %>
          <%= button_to "Remove", settings_member_path(membership), method: :delete, data: { turbo_confirm: "Remove this member?" }, class: "text-sm text-red-600 hover:underline cursor-pointer" %>
        <% end %>
      </div>
    <% end %>
  </div>
</div>

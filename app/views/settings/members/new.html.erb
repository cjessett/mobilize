<%= render "shared/flash" %>
<%= back_link "Members", settings_members_path %>
<h1 class="font-bold text-3xl text-gray-900 dark:text-white mt-2">Invite a Member</h1>

<%= form_with url: settings_members_path, class: "contents" do |form| %>
  <%= form_card do %>
    <%= form_row "Name" do %>
      <div class="grid grid-cols-2 gap-4">
        <%= form.text_field :first_name, placeholder: "First name", required: true, class: ui_input %>
        <%= form.text_field :last_name, placeholder: "Last name", class: ui_input %>
      </div>
    <% end %>

    <%= form_row "Email", hint: "They'll receive an email to set their password." do %>
      <%= form.email_field :email_address, required: true, class: ui_input %>
    <% end %>

    <%= form_row "Role" do %>
      <div class="space-y-4">
        <% { "organizer" => [ "Organizer", "Day-to-day organizing: people, texting, events." ],
             "admin" => [ "Admin", "Everything, including settings, chapters, and members." ] }.each do |value, (label, description)| %>
          <label class="flex items-start gap-3 cursor-pointer">
            <%= radio_button_tag "role", value, value == "organizer", class: "mt-1 h-5 w-5 accent-indigo-500" %>
            <span>
              <span class="block font-medium text-gray-900 dark:text-white"><%= label %></span>
              <span class="block text-sm text-gray-400 dark:text-slate-500"><%= description %></span>
            </span>
          </label>
        <% end %>
      </div>
    <% end %>

    <%= form_row "Chapter access" do %>
      <%= select_tag "chapter_id", options_for_select([ [ "All chapters (organization-wide)", "" ] ] + current_organization.chapters.order(:name).map { |c| [ c.name, c.id ] }), class: ui_input %>
    <% end %>

    <%= form_actions do %>
      <%= form.submit "Send Invite", class: "rounded-md px-4 py-2.5 bg-indigo-500 hover:bg-indigo-400 text-white font-medium cursor-pointer" %>
    <% end %>
  <% end %>
<% end %>

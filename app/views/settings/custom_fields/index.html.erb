<%= render "shared/flash" %>

<h1 class="font-bold text-3xl text-gray-900 dark:text-white mb-6">Settings</h1>

<div class="bg-white dark:bg-slate-800/40 rounded-xl border border-gray-200 dark:border-slate-700/70">
  <%= render "settings/nav" %>

  <div class="overflow-x-auto">

  <table class="w-full text-left min-w-[40rem]">
    <thead>
      <tr class="text-xs uppercase tracking-wider text-gray-400 dark:text-slate-500">
        <th class="px-6 py-4 font-semibold">Property</th>
        <th class="px-4 py-4 font-semibold">Key</th>
        <th class="px-4 py-4 font-semibold">Type</th>
        <th class="px-4 py-4 font-semibold text-right pr-6">Actions</th>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-200 dark:divide-slate-700/60">
      <% if @custom_fields.empty? %>
        <tr><td colspan="4" class="px-6 py-8 text-gray-500 dark:text-slate-400">No properties yet. Properties are custom fields stored on each person.</td></tr>
      <% end %>
      <% @custom_fields.each do |field| %>
        <tr class="hover:bg-gray-50 dark:hover:bg-slate-800">
          <td class="px-6 py-4 font-medium text-gray-900 dark:text-white"><%= field.label %></td>
          <td class="px-4 py-4 text-sm text-gray-500 dark:text-slate-400 font-mono"><%= field.key %></td>
          <td class="px-4 py-4 text-sm text-gray-700 dark:text-slate-300"><%= field.field_type %></td>
          <td class="px-4 py-4 pr-6">
            <div class="flex justify-end">
              <%= button_to "Remove", settings_custom_field_path(field), method: :delete, data: { turbo_confirm: "Remove this property? Values stored on people are kept but hidden." }, class: "text-sm text-red-600 dark:text-red-400 hover:underline cursor-pointer" %>
            </div>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
  </div>

  <%= form_with model: @custom_field, url: settings_custom_fields_path, class: "contents" do |form| %>
    <div class="border-t border-gray-200 dark:border-slate-700/70 px-4 md:px-6 py-5 flex flex-wrap gap-3 items-end">
      <div class="flex-1 max-w-xs">
        <label class="block text-xs font-semibold tracking-widest uppercase text-gray-400 dark:text-slate-500 mb-2">Label</label>
        <%= form.text_field :label, required: true, class: ui_input %>
      </div>
      <div>
        <label class="block text-xs font-semibold tracking-widest uppercase text-gray-400 dark:text-slate-500 mb-2">Type</label>
        <%= form.select :field_type, CustomField::FIELD_TYPES, {}, { class: ui_input } %>
      </div>
      <%= form.submit "Add Property", class: "rounded-md px-4 py-2.5 bg-indigo-500 hover:bg-indigo-400 text-white text-sm font-medium cursor-pointer" %>
    </div>
  <% end %>
</div>
